# Babycat — 환경변수 템플릿
# 사용: cp .env.example .env && 값 채우기. 실제 .env는 .gitignore에 등록되어 트래킹되지 않는다.

# 젯슨 자체의 외부 도달 가능 IP (zerotier 또는 LAN). WebRTC ICE candidate로
# 광고된다. 비우면 브라우저(다른 노드)가 mediamtx에 도달 못해 WebRTC 실패.
# 콤마 구분으로 여러 개 가능 (예: 192.168.1.10,172.27.1.205).
HOST_IP=172.27.1.205

# 선택 가능한 VLM 모델 목록 (콤마 구분). 첫 번째 항목이 부팅 시 기본 로드됨.
# 추가 모델은 .so 미존재 시 부팅 시 서브프로세스로 컴파일(수~수십 분/모델) 후 캐시.
# 현재는 VILA1.5-3b 단일 운영. 추가 후보는 NanoLLM 지원 VLM 중 Orin NX 16GB에
# 맞는 3B급에 한정 (동시 로드 불가, 전환 시 .so 캐시 기반 로드만 가능).
# VLM_MODELS=Efficient-Large-Model/VILA1.5-3b

# JWT 서명 시크릿 (app·api 컨테이너 공유). 미설정 시 default 사용.
# JWT_SECRET=change-me

# 초기 admin 계정 (최초 부팅 시 1회 시딩).
# DEFAULT_USER=admin
# DEFAULT_PASS=admin
