# Babycat — environment variable template
# Usage: cp .env.example .env && fill in values. The actual .env is gitignored and not tracked.

# The Jetson's externally reachable IP (zerotier or LAN). Advertised as a WebRTC
# ICE candidate. If empty, browsers (other nodes) can't reach mediamtx and WebRTC fails.
# Comma-separated for multiple (e.g. 192.168.1.10,172.27.1.205,etc.).
HOST_IP=127.0.0.1

# JWT signing secret (shared between the engine and gateway containers).
JWT_SECRET=babycat-default-secret

# Access-token lifetime in seconds.
JWT_EXPIRY=600

# Refresh-token lifetime in seconds.
REFRESH_EXPIRY=2592000

# Candidate VLM model list (comma-separated). The first entry is the boot default.
# Additional models are compiled in a subprocess at boot when the .so is missing
# (minutes to tens of minutes per model), then cached.
# Currently only VILA1.5-3b is in operation. Additional candidates are limited to
# NanoLLM-supported 3B-class VLMs that fit on Orin NX 16GB (no concurrent loading;
# switching is .so-cache-based load only).
VLM_MODELS=Efficient-Large-Model/VILA1.5-3b

# Upper bound on tokens generated per VLM inference. Counted in tokens (not
# characters); for English, 1 token ≈ 4 characters, Korean is shorter.
# Stop markers (</s>, <|im_end|>, etc.) may truncate earlier. Raise this when
# the default prompt elicits sentences that get cut off mid-word.
MAX_NEW_TOKENS=32

# ── Inference cadence tuning (NOT YET WIRED — for future implementation) ──
# Defaults in app/main.py and currently NOT forwarded through docker-compose:
#   N_FRAMES   = 4    # frames pulled from the ring per inference (≈ window length)
#   TARGET_FPS = 1.0  # videorate normalization rate, i.e. one frame per second
#
# Default window: (N_FRAMES - 1) / TARGET_FPS = 3s. The inference worker fires
# back-to-back, so the time between inferences is bounded by inference latency.
#
# Observation: on a slow device (e.g. Orin NX, ~4–5s per inference) consecutive
# inferences see almost entirely new frames; on a fast device (e.g. AGX Orin,
# ~1–2s) only 1–2 frames change between calls, making the VLM look as if it is
# staring at a still image.
#
# Mitigation options when implementing later:
#   A) Lower TARGET_FPS (e.g. 0.5) to widen the window via frame spacing.
#   B) Raise N_FRAMES (e.g. 8) to widen the window via more samples.
#   C) Introduce a new INFER_MIN_INTERVAL (seconds) and skip queue signals
#      arriving sooner than that — rate-limits only the fast device.
#
# When wiring any of these:
#   1. Already env-driven in app/main.py (no code change for A/B).
#   2. Forward in docker-compose.yml app service (e.g. - N_FRAMES=${N_FRAMES:-4}).
#   3. Uncomment / add the lines below.
# N_FRAMES=4
# TARGET_FPS=1.0
# INFER_MIN_INTERVAL=0

# Initial admin account (seeded once on first boot).
DEFAULT_USER=admin
DEFAULT_PASS=admin
