# Babycat web defaults for Vite development.
# Runtime user settings saved from the login page override these values.

# Leave empty when web, api, app, and MediaMTX are served from the same browser host.
VITE_BABYCAT_HOST=

# Optional explicit service URLs. Usually not needed when VITE_BABYCAT_HOST is set.
VITE_BABYCAT_API_URL=
VITE_BABYCAT_APP_URL=
VITE_BABYCAT_HLS_URL=
VITE_BABYCAT_WHEP_URL=
